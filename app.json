{
  "expo": {
    "name": "SOS Safety",
    "slug": "sos-radar-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sosapp",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Emergency SOS ke liye aapki location zaroori hai",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SOS active hone par background mein location track karne ke liye",
        "NSLocationAlwaysUsageDescription": "SOS active hone par background mein location share karne ke liye"
      }
    },
    "android": {
"splash": {
  "image": "./assets/icon.png",
  "resizeMode": "contain",
  "backgroundColor": "#0a0a0a"
},      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "SEND_SMS",
        "RECEIVE_SMS",
        "READ_CONTACTS",
        "VIBRATE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.yourname.sosradarapp"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF3B30"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d862c320-ac76-46ff-8b66-51f3d722b549"
      }
    },
    "owner": "laxmikonar"
  }
}
